generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ENUMS

enum UserStatus {
  online
  offline
  away
  dnd
}

enum WorkspaceRole {
  owner
  admin
  member
}

enum Plan {
  free
  pro
}

enum ChannelType {
  public
  private
  dm
}

enum NotificationType {
  mention
  task_assigned
  channel_invite
}

enum MessageType {
  text
  file
  mixed
  system
}

// MODELS

model User {
  id                 String     @id @default(uuid())
  email              String     @unique
  password_hash      String
  refresh_token_hash String?
  display_name       String
  avatar_url         String?
  status             UserStatus @default(offline)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // relations
  workspace_members WorkspaceMember[]
  owned_workspaces  Workspace[]       @relation("WorkspaceOwner")
  created_invites   Invite[]          @relation("InviteCreator")

  messages          Message[]         @relation("MessageSender")

  message_reactions  MessageReaction[]
  message_mentions   MessageMention[]

  Channel           Channel[]
  ChannelMember     ChannelMember[]
  notifications     Notification[]
  documents         Document[] @relation("DocumentCreator")
  edited_documents  Document[] @relation("DocumentLastEditor")
  attachments       Attachment[] @relation("AttachmentUploader")
}


model Message {
  id              String   @id @default(uuid())
  channelId       String
  senderId        String

  parentMessageId String?

  content         String
  messageType     MessageType

  isEdited        Boolean  @default(false)

  deletedAt       DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  parentMessage   Message? @relation("Replies", fields: [parentMessageId], references: [id])

  replies         Message[] @relation("Replies")

  channel         Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  sender          User @relation("MessageSender", fields: [senderId], references: [id])



  reactions       MessageReaction[]
  mentions        MessageMention[]
  attachments     MessageAttachment[]

  @@index([channelId, createdAt])
  @@index([parentMessageId])
  @@index([senderId])
  @@index([deletedAt])
}


model MessageReaction {
  id        String   @id @default(uuid())

  messageId String
  userId    String

  emoji     String

  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])

  @@index([messageId])
  @@index([userId])
}


model MessageMention {
  id                String   @id @default(uuid())

  messageId         String
  mentionedUserId   String

  createdAt         DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  user    User @relation(fields: [mentionedUserId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([mentionedUserId])
}





model Workspace {
  id       String  @id @default(uuid())
  name     String
  slug     String  @unique
  logo_url String?
  plan     Plan    @default(free)

  owner_id String

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // relations
  owner   User              @relation("WorkspaceOwner", fields: [owner_id], references: [id])
  members WorkspaceMember[]
  invites Invite[]
  Channel Channel[]
  documents Document[]

  @@index([owner_id])
}

model WorkspaceMember {
  workspace_id String
  user_id      String
  role         WorkspaceRole @default(member)

  joined_at DateTime @default(now())

  // relations
  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([workspace_id, user_id])
  @@index([user_id])
  @@index([workspace_id])
}

model Invite {
  id            String    @id @default(uuid())
  code          String    @unique
  workspace_id  String
  created_by_id String
  expires_at    DateTime?
  max_uses      Int?
  uses          Int       @default(0)

  created_at DateTime @default(now())

  // relations
  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  creator   User      @relation("InviteCreator", fields: [created_by_id], references: [id])

  @@index([workspace_id])
  @@index([code])
}

model Channel {
  id              String      @id @default(uuid())
  workspace_id    String
  name            String
  type            ChannelType @default(public)
  created_by_id   String
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt
  last_message_at DateTime?
  messages Message[]

  // relations
  workspace Workspace       @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  creator   User            @relation(fields: [created_by_id], references: [id])
  members   ChannelMember[]
  

  @@index([workspace_id])
}

model ChannelMember {
  channel_id String
  user_id    String
  joined_at  DateTime @default(now())

  // relations
  channel Channel @relation(fields: [channel_id], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([channel_id, user_id])
  @@index([user_id])
}

model Notification {
  id         String           @id @default(uuid())
  user_id    String
  type       NotificationType
  title      String
  body       String
  data       Json?
  is_read    Boolean          @default(false)
  created_at DateTime         @default(now())

  // relations
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model Document {
  id                 String   @id @default(uuid())

  workspace_id       String
  created_by_id      String
  last_edited_by_id  String?

  title              String   @default("Untitled")
  content            Json?
  icon               String?
  cover_url          String?

  is_archived        Boolean  @default(false)
  archived_at        DateTime?

  parent_id          String?

  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  // Relations
  workspace   Workspace  @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  creator     User       @relation("DocumentCreator", fields: [created_by_id], references: [id])
  last_editor User?      @relation("DocumentLastEditor", fields: [last_edited_by_id], references: [id])
  parent      Document?  @relation("DocumentHierarchy", fields: [parent_id], references: [id])
  children    Document[] @relation("DocumentHierarchy")
  attachments DocumentAttachment[]

  @@index([workspace_id])
  @@index([created_by_id])
  @@index([last_edited_by_id])
  @@index([parent_id])
  @@index([is_archived])
  @@index([workspace_id, is_archived])
}

//simple task model placeholder
model Task {
  id        String @id @default(uuid())
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attachments TaskAttachment[]
}

model Attachment {
  id          String   @id @default(uuid())

  file_name   String
  url         String
  file_type   String
  file_size   Int

  uploaded_by String
  created_at  DateTime @default(now())

  message_attachments   MessageAttachment[]
  document_attachments  DocumentAttachment[]
  task_attachments      TaskAttachment[]

  uploader User @relation("AttachmentUploader", fields: [uploaded_by], references: [id], onDelete: Cascade)

  @@index([uploaded_by])
}

model MessageAttachment {
  id            String   @id @default(uuid())

  messageId     String
  attachmentId  String

  createdAt     DateTime @default(now())

  message    Message    @relation(fields: [messageId], references: [id], onDelete: Cascade)

  attachment Attachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)

  @@unique([messageId, attachmentId])

  @@index([messageId])
  @@index([attachmentId])
}

model DocumentAttachment {
  id            String   @id @default(uuid())

  documentId    String
  attachmentId  String

  createdAt     DateTime @default(now())

  document   Document   @relation(fields: [documentId], references: [id], onDelete: Cascade)

  attachment Attachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)

  @@unique([documentId, attachmentId])

  @@index([documentId])
  @@index([attachmentId])
}

model TaskAttachment {
  id            String   @id @default(uuid())

  taskId        String
  attachmentId  String

  createdAt     DateTime @default(now())

  task       Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)

  attachment Attachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)

  @@unique([taskId, attachmentId])

  @@index([taskId])
  @@index([attachmentId])
}

