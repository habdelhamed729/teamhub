generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ENUMS

enum UserStatus {
  online
  offline
  away
  dnd
}

enum WorkspaceRole {
  owner
  admin
  member
}

enum Plan {
  free
  pro
}

enum ChannelType {
  public
  private
  dm
}

enum NotificationType {
  mention
  task_assigned
  channel_invite
}

// MODELS

model User {
  id                 String     @id @default(uuid())
  email              String     @unique
  password_hash      String
  refresh_token_hash String?
  display_name       String
  avatar_url         String?
  status             UserStatus @default(offline)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // relations
  workspace_members WorkspaceMember[]
  owned_workspaces  Workspace[]       @relation("WorkspaceOwner")
  created_invites   Invite[]          @relation("InviteCreator")
  Channel           Channel[]
  ChannelMember     ChannelMember[]
  notifications     Notification[]
  documents         Document[] @relation("DocumentCreator")
  edited_documents  Document[] @relation("DocumentLastEditor")
  attachments       Attachment[] @relation("AttachmentUploader")
}

model Workspace {
  id       String  @id @default(uuid())
  name     String
  slug     String  @unique
  logo_url String?
  plan     Plan    @default(free)

  owner_id String

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // relations
  owner   User              @relation("WorkspaceOwner", fields: [owner_id], references: [id])
  members WorkspaceMember[]
  invites Invite[]
  Channel Channel[]
  documents Document[]

  @@index([owner_id])
}

model WorkspaceMember {
  workspace_id String
  user_id      String
  role         WorkspaceRole @default(member)

  joined_at DateTime @default(now())

  // relations
  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([workspace_id, user_id])
  @@index([user_id])
  @@index([workspace_id])
}

model Invite {
  id            String    @id @default(uuid())
  code          String    @unique
  workspace_id  String
  created_by_id String
  expires_at    DateTime?
  max_uses      Int?
  uses          Int       @default(0)

  created_at DateTime @default(now())

  // relations
  workspace Workspace @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  creator   User      @relation("InviteCreator", fields: [created_by_id], references: [id])

  @@index([workspace_id])
  @@index([code])
}

model Channel {
  id              String      @id @default(uuid())
  workspace_id    String
  name            String
  type            ChannelType @default(public)
  created_by_id   String
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt
  last_message_at DateTime?

  // relations
  workspace Workspace       @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  creator   User            @relation(fields: [created_by_id], references: [id])
  members   ChannelMember[]

  @@index([workspace_id])
}

model ChannelMember {
  channel_id String
  user_id    String
  joined_at  DateTime @default(now())

  // relations
  channel Channel @relation(fields: [channel_id], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([channel_id, user_id])
  @@index([user_id])
}

model Notification {
  id         String           @id @default(uuid())
  user_id    String
  type       NotificationType
  title      String
  body       String
  data       Json?
  is_read    Boolean          @default(false)
  created_at DateTime         @default(now())

  // relations
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model Document {
  id                 String   @id @default(uuid())

  workspace_id       String
  created_by_id      String
  last_edited_by_id  String?

  title              String   @default("Untitled")
  content            Json?

  is_archived        Boolean  @default(false)

  parent_id          String?

  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  // Relations
  workspace   Workspace  @relation(fields: [workspace_id], references: [id], onDelete: Cascade)
  creator     User       @relation("DocumentCreator", fields: [created_by_id], references: [id])
  last_editor User?      @relation("DocumentLastEditor", fields: [last_edited_by_id], references: [id])
  parent      Document?  @relation("DocumentHierarchy", fields: [parent_id], references: [id])
  children    Document[] @relation("DocumentHierarchy")
  attachments Attachment[]

  @@index([workspace_id])
  @@index([created_by_id])
  @@index([last_edited_by_id])
  @@index([parent_id])
  @@index([is_archived])
  @@index([workspace_id, is_archived])
}

model Attachment {
  id            String   @id @default(uuid())
  file_name     String
  url           String
  file_type     String
  file_size     Int
  uploaded_by   String

  // Exactly one of these must be non-null (enforced by CHECK constraint)
  message_id    String?
  task_id       String?
  document_id   String?

  created_at    DateTime @default(now())

  // Relations
  uploader User      @relation("AttachmentUploader", fields: [uploaded_by], references: [id])
  document Document? @relation(fields: [document_id], references: [id], onDelete: Cascade)

  @@index([uploaded_by])
  @@index([message_id])
  @@index([task_id])
  @@index([document_id])
}
