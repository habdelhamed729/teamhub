# Database (Neon PostgreSQL with asyncpg driver for SQLAlchemy)
# NOTE: The driver must be asyncpg (e.g. postgresql+asyncpg://...)
DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/teamhub"

# AI Providers (Groq Cloud API Key)
GROQ_API_KEY="your-groq-api-key-here" 

# Service Authentication (Must match the AI_SERVICE_TOKEN in the main API gateway)
AI_SERVICE_TOKEN="your-shared-ai-service-token-secret"

# Embedding Model (HuggingFace sentence-transformers model name)
EMBEDDING_MODEL="all-MiniLM-L6-v2"

# Default LLM Models from Groq
DEFAULT_LLM_MODEL="llama-3.1-8b-instant"
STRONG_LLM_MODEL="llama-3.3-70b-versatile"

# Rate Limiting configuration
MAX_REQUESTS_PER_MINUTE=25
