# TeamHub Docker Environment Variables Template
# Copy this file to `.env` in the root folder before starting containers:
# cp docker.env.example .env

# Database configuration
# (Note: Host is set to 'db' which resolves to the teamhub-db container)
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=teamhub

# API Gateway secrets
JWT_ACCESS_SECRET=your-super-secret-access-key-minimum-32-characters
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-characters
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Third-party integrations (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AI Provider Settings
# REQUIRED: You must add your Groq API Key here to use LLM/Agent features
GROQ_API_KEY=your-groq-api-key-here

# Shared token for API Gateway <-> AI Microservice auth
AI_SERVICE_TOKEN=your-shared-ai-service-token-secret
